---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import Heading from "../components/ui/Heading.astro";
import Button from "../components/ui/Button.astro";
---

<BaseLayout
  title="flowstaite – Dein KI-Kollege"
  description="flowstaite ist dein KI-nativer Kollege, der zusieht, lernt und eigenständig Routine-Aufgaben erledigt. Trag deine Mailadresse ein und sei dabei."
>
  <!-- Hero: Vollbild-Bild mit Overlay und Claim -->
  <section class="hero" aria-labelledby="hero-heading">
    <img
      class="hero__img"
      src="/images/hero.jpg"
      alt="Zwei Personen arbeiten gemeinsam am Laptop"
      width="1600"
      height="1107"
    />
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="hero__content">
      <h1 class="hero__heading" id="hero-heading">
        Dein KI-Kollege, den du<br />nicht einstellen musst.
      </h1>
    </div>
    <div class="hero__scroll" aria-hidden="true">
      <svg class="hero__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19" />
        <polyline points="19 12 12 19 5 12" />
      </svg>
    </div>
  </section>

  <!-- Was ist flowstaite? -->
  <section class="section" aria-labelledby="what-heading">
    <Container size="narrow">
      <Heading level={2} id="what-heading">
        <span>Was ist flowst</span><span class="accent">ai</span><span>te?</span>
      </Heading>
      <p class="section__text">
        flowstaite ist ein digitaler KI-Kollege, der zusieht, lernt, Muster
        erkennt und dann eigenständig Routine-Aufgaben erledigt. Eine
        Agent-First-Software, die euch während der Arbeit dort unterstützt,
        wo es am meisten nützt.
      </p>
    </Container>
  </section>

  <!-- Wie funktioniert flowstaite? -->
  <section class="section" aria-labelledby="how-heading">
    <Container size="narrow">
      <Heading level={2} id="how-heading">
        <span>Wie funktioniert flowst</span><span class="accent">ai</span><span>te?</span>
      </Heading>
      <ol class="steps">
        <li class="steps__item">
          <span class="steps__number">1</span>
          <div class="steps__body">
            <h3 class="steps__title">Lernen</h3>
            <p class="steps__text">
              flowstaite fragt, ob er sehen darf was du tust und beobachtet
              dann nur das was freigegeben wurden. Er lernt, wie
              euer Betrieb tickt, fragt nach und erkennt Muster.
            </p>
          </div>
        </li>
        <li class="steps__item">
          <span class="steps__number">2</span>
          <div class="steps__body">
            <h3 class="steps__title">Vorschlagen</h3>
            <p class="steps__text">
              Hat flowstaite einen Überblick über das Unternehmen und die
              verschiedenen Abteilungen, schlägt er euch vor, wie man Dinge effizienter gestalten kann und was er übernehmen könnte. Ihr reviewt jeden Vorschlag. flowstaite lernt aus euren
              Korrekturen und wird mit jeder Runde besser.
            </p>
          </div>
        </li>
        <li class="steps__item">
          <span class="steps__number">3</span>
          <div class="steps__body">
            <h3 class="steps__title">Übernehmen</h3>
            <p class="steps__text">
              Wir setzen dabei auf den Human in the Loop, nichts soll ausgeführt
              werden ohne vorher menschlich geprüft worden zu sein. Ist das
              Vorhaben freigegeben, arbeitet flowstaite selbstständig, ihr
              behaltet die Kontrolle über das was passiert.
            </p>
          </div>
        </li>
      </ol>
    </Container>
  </section>

  <!-- Wer ist flowstaite? -->
  <section class="section" aria-labelledby="team-heading">
    <Container size="narrow">
      <Heading level={2} id="team-heading">
        <span>Wer ist flowst</span><span class="accent">ai</span><span>te?</span>
      </Heading>
    
      <ul class="team" role="list">
        <li class="team__member">
          <img
            class="team__photo"
            src="/images/team/luca.jpg"
            alt="Portrait von Luca"
            width="600"
            height="600"
            loading="lazy"
          />
          <h3 class="team__name">Luca <span class="team__role">CEO</span></h3>
          <p class="team__desc">
            Informatik & Wirtschaft. Business Development und Architektur.
          </p>
        </li>
        <li class="team__member">
          <img
            class="team__photo"
            src="/images/team/jessica.jpg"
            alt="Portrait von Jessica"
            width="600"
            height="600"
            loading="lazy"
          />
          <h3 class="team__name">Jessica <span class="team__role">CMO</span></h3>
          <p class="team__desc">
            Kommunikationsdesign. Produktvision, User & Agentic Experience.
          </p>
        </li>
        <li class="team__member">
          <img
            class="team__photo"
            src="/images/team/vincent.jpg"
            alt="Portrait von Vincent"
            width="600"
            height="600"
            loading="lazy"
          />
          <h3 class="team__name">Vincent <span class="team__role">CTO</span></h3>
          <p class="team__desc">
            Intelligente interaktive Systeme. KI und Backend.
          </p>
        </li>
      </ul>
    </Container>
  </section>

  <!-- Gemeinsam gestalten -->
  <section class="section" aria-labelledby="together-heading">
    <Container size="narrow">
      <Heading level={2} id="together-heading">Gemeinsam gestalten,<br />was als Nächstes kommt.</Heading>
      <p class="section__text">
        flowstaite befindet sich im Aufbau. Aktuell suchen wir noch nach
        weiteren Unternehmen, welche mit uns gemeinsam weiterentwickeln, damit wir zusammen aus flowstaite die qualitativ hochwertigste Hilfestellung
        für Mitarbeitende und Unternehmen schaffen können. Um so gut zu
        helfen wie möglich, brauchen wir aktiven Austausch mit verschiedenen
        Perspektiven. Wenn du neugierig bist auf das, was entsteht, freuen
        wir uns darüber, dich auf dem Laufenden zu halten.
      </p>
    </Container>
  </section>

  <!-- Signup + Footer-Bereich: durchgehender Surface-Hintergrund -->
  <div class="bottom-surface">
    <section class="section" aria-labelledby="dabei-sein">
      <Container size="narrow">
        <Heading level={2} id="dabei-sein">Dabei sein</Heading>
        <p class="section__text">
          Interesse daran, gemeinsam mit uns die nächsten Schritte zu gehen oder auf dem Laufenden zu
          bleiben? Trag dich ein, wir melden uns!
        </p>

        <form
          class="signup-form"
          id="signup-form"
          method="POST"
          action="https://api.web3forms.com/submit"
          novalidate
        >
          <input type="hidden" name="access_key" value="6659ce9d-9197-4594-8573-f0f163e3e183" />
          <input type="hidden" name="subject" value="Neue Anmeldung – flowstaite" />
          <fieldset class="signup-form__interests">
            <legend class="signup-form__legend">Was interessiert dich?</legend>
            <div class="signup-form__pills">
              <label class="signup-pill">
                <input class="signup-pill__input" type="checkbox" name="interest" value="Auf dem Laufenden bleiben" />
                <span class="signup-pill__label">Auf dem Laufenden bleiben</span>
              </label>
              <label class="signup-pill">
                <input class="signup-pill__input" type="checkbox" name="interest" value="Mitgestalten" />
                <span class="signup-pill__label">Mitgestalten</span>
              </label>
            </div>
            <span class="signup-form__error" id="interest-error" aria-live="polite" hidden>
              Bitte wähle mindestens eine Option.
            </span>
          </fieldset>

          <fieldset class="signup-form__interests">
            <legend class="signup-form__legend">Was beschreibt dich?</legend>
            <div class="signup-form__pills">
              <label class="signup-pill">
                <input class="signup-pill__input" type="checkbox" name="rolle" value="Ich arbeite bei einem Unternehmen" />
                <span class="signup-pill__label">Ich arbeite bei einem Unternehmen</span>
              </label>
              <label class="signup-pill">
                <input class="signup-pill__input" type="checkbox" name="rolle" value="Ich führe ein Unternehmen" />
                <span class="signup-pill__label">Ich führe ein Unternehmen</span>
              </label>
            </div>
          </fieldset>

          <div class="signup-form__name-row">
            <div class="signup-form__field">
              <label class="signup-form__label" for="firstname">Vorname</label>
              <input
                class="signup-form__input"
                type="text"
                id="firstname"
                name="vorname"
                autocomplete="given-name"
                required
                placeholder="Dein Vorname"
              />
            </div>
            <div class="signup-form__field">
              <label class="signup-form__label" for="lastname">Nachname</label>
              <input
                class="signup-form__input"
                type="text"
                id="lastname"
                name="nachname"
                autocomplete="family-name"
                required
                placeholder="Dein Nachname"
              />
            </div>
          </div>

          <div class="signup-form__row">
            <div class="signup-form__field">
              <label class="signup-form__label" for="email">Mailadresse</label>
              <input
                class="signup-form__input"
                type="email"
                id="email"
                name="email"
                autocomplete="email"
                required
                placeholder="deine@mail.de"
              />
            </div>

            <Button type="submit" variant="primary" size="md" id="signup-submit">
              Eintragen
            </Button>
          </div>

          <span class="signup-form__error" id="form-error" aria-live="polite" hidden>
            Bitte fülle alle Felder aus.
          </span>

          <p class="signup-form__privacy">
            Mit dem Absenden stimmst du der Verarbeitung deiner Daten gemäß unserer
            <a href="/datenschutz">Datenschutzerklärung</a> zu.
          </p>
        </form>

        <div class="signup-success" id="signup-success" hidden aria-live="polite" role="status">
          <p class="signup-success__text">Danke, wir melden uns.</p>
        </div>
      </Container>
    </section>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById("signup-form") as HTMLFormElement | null;
  const submitBtn = document.getElementById("signup-submit") as HTMLButtonElement | null;
  const successEl = document.getElementById("signup-success") as HTMLElement | null;
  const formError = document.getElementById("form-error") as HTMLElement | null;
  const interestError = document.getElementById("interest-error") as HTMLElement | null;

  if (form && submitBtn && successEl && formError && interestError) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const data = new FormData(form);
      const interests = data.getAll("interest");
      const email = (data.get("email") as string || "").trim();
      const vorname = (data.get("vorname") as string || "").trim();
      const nachname = (data.get("nachname") as string || "").trim();
      const emailInput = form.querySelector<HTMLInputElement>("#email")!;

      interestError.hidden = true;
      formError.hidden = true;

      if (interests.length === 0) {
        interestError.hidden = false;
        return;
      }

      if (!vorname || !nachname || !emailInput.validity.valid) {
        formError.textContent = "Bitte fülle alle Felder aus.";
        formError.hidden = false;
        return;
      }

      submitBtn.setAttribute("aria-busy", "true");
      submitBtn.disabled = true;

      try {
        const response = await fetch(form.action, {
          method: "POST",
          headers: { Accept: "application/json" },
          body: data,
        });

        if (!response.ok) {
          throw new Error("Form submission failed");
        }

        form.hidden = true;
        successEl.hidden = false;
      } catch {
        formError.textContent =
          "Da ist etwas schiefgegangen. Bitte versuche es gleich nochmal.";
        formError.hidden = false;
        submitBtn.removeAttribute("aria-busy");
        submitBtn.disabled = false;
      }
    });
  }
</script>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    overflow: hidden;
    height: 100vh;
    height: 100svh;
    display: grid;
    align-items: end;
  }

  .hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.2) 0%,
      rgba(0, 0, 0, 0.6) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    padding: var(--space-xl) var(--space-xl) var(--space-2xl);
    max-width: var(--container-default);
  }

  .hero__heading {
    font-family: var(--font-serif);
    font-weight: var(--weight-bold);
    font-size: clamp(2.25rem, 5vw, 4rem);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-bg);
    margin: 0;
  }

  /* Scroll-Pfeil */
  .hero__scroll {
    position: absolute;
    right: var(--space-xl);
    bottom: var(--space-2xl);
    z-index: 1;
    animation: hero-bounce 2s ease-in-out infinite;
  }

  .hero__arrow {
    width: 2rem;
    height: 2rem;
    color: var(--color-bg);
    opacity: 0.8;
  }

  @keyframes hero-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(0.5rem); }
  }

  /* ── Sections ── */
  /*
   * Nur oberes Padding: so betraegt der Abstand zwischen zwei
   * Sections genau eine padding-Einheit (--space-3xl) und ist
   * identisch mit dem Abstand Hero -> "Was ist flowstaite?".
   * Das untere Ende der Seite faengt .bottom-surface ab.
   */
  .section {
    padding-block: var(--space-3xl) 0;
    padding-inline: var(--space-xl);
  }

  .section__text {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
    max-width: 52ch;
    margin-block-start: var(--space-md);
  }

  /*
   * Schliesst eine Section mit einem Absatz ab, wird dessen
   * Standard-Aussenabstand entfernt, damit der Abstand zur
   * naechsten Section exakt eine padding-Einheit betraegt.
   */
  .section__text:last-child {
    margin-block-end: 0;
  }

  .accent {
    color: var(--color-accent);
  }

  /* ── Team (Wer ist flowstaite?) ── */
  .team {
    list-style: none;
    padding: 0;
    margin-block: var(--space-xl) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  @media (min-width: 40em) {
    .team {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-lg);
    }

    .team__member {
      display: grid;
      grid-row: span 3;
      grid-template-rows: subgrid;
      /* Den vom Eltern-Grid geerbten Zeilenabstand neutralisieren,
         damit Foto, Name und Beschreibung nur ueber ihre Margins
         (wie im mobilen Layout) Abstand halten. */
      row-gap: 0;
      justify-items: center;
    }
  }

  .team__member {
    text-align: center;
  }

  .team__photo {
    width: min(100%, 12rem);
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: var(--radius-pill);
    margin-inline: auto;
    display: block;
    filter: grayscale(1);
  }

  .team__name {
    font-family: var(--font-serif);
    font-weight: var(--weight-bold);
    font-size: var(--text-xl);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-block: var(--space-md) var(--space-2xs);
  }

  .team__role {
    font-family: var(--font-sans);
    font-weight: var(--weight-medium);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .team__desc {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin: 0;
  }

  @media (min-width: 40em) {
    .team__desc {
      max-width: 32ch;
      margin-inline: auto;
    }
  }

  /* ── Durchgehender Surface-Hintergrund ab "Dabei sein" bis Footer ── */
  .bottom-surface {
    background-color: var(--color-surface);
    padding-block-end: var(--space-3xl);
  }

  /*
   * Uebergang zur Surface-Flaeche: der Farbwechsel soll mittig im
   * Section-Abstand liegen. Die vorhergehende Section traegt die
   * obere Haelfte (cream), "Dabei sein" die untere (surface).
   * Summe bleibt eine padding-Einheit (2x --space-xl = --space-3xl).
   */
  .section:has(+ .bottom-surface) {
    padding-block-end: var(--space-xl);
  }

  .bottom-surface .section {
    padding-block-start: var(--space-xl);
  }

  /* ── Steps (Wie funktioniert flowstaite?) ── */
  .steps {
    list-style: none;
    padding: 0;
    margin-block: var(--space-xl) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .steps__item {
    display: flex;
    gap: var(--space-xs);
    align-items: flex-start;
  }

  @media (min-width: 40em) {
    .steps__item {
      gap: var(--space-md);
    }
  }

  .steps__number {
    flex-shrink: 0;
    font-family: var(--font-serif);
    font-weight: var(--weight-bold);
    font-size: 4.5rem;
    line-height: 0.7;
    color: var(--color-accent);
    width: 2.75rem;
    text-align: left;
  }

  @media (min-width: 40em) {
    .steps__number {
      width: 3.75rem;
      text-align: center;
    }
  }

  .steps__body {
    flex: 1;
  }

  .steps__title {
    font-family: var(--font-serif);
    font-weight: var(--weight-bold);
    font-size: var(--text-xl);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin: 0 0 var(--space-2xs);
  }

  .steps__text {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 48ch;
  }

  /* ── Signup Form ── */
  .signup-form__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    flex: 1 1 auto;
  }

  .signup-form__label {
    font-weight: var(--weight-medium);
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .signup-form__input {
    padding: var(--space-xs) var(--space-md);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: var(--leading-snug);
    color: var(--color-text);
    background-color: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-xl);
    transition: border-color var(--duration-fast) var(--ease-standard);
    min-width: 0;
    box-sizing: border-box;
  }

  .signup-form__input::placeholder {
    color: var(--color-border-strong);
  }

  .signup-form__input:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
    border-color: var(--color-focus);
  }

  .signup-form__input[aria-invalid="true"] {
    border-color: var(--color-error);
  }

  .signup-form__error {
    font-size: var(--text-sm);
    color: var(--color-error);
  }

  .signup-form__privacy {
    margin-block-start: var(--space-md);
    margin-block-end: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  .signup-form__privacy a {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .signup-form__interests {
    border: 0;
    padding: 0;
    margin: 0 0 var(--space-md);
  }

  .signup-form__legend {
    font-weight: var(--weight-medium);
    font-size: var(--text-sm);
    color: var(--color-text);
    margin-block-end: var(--space-xs);
  }

  .signup-form__pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .signup-pill {
    cursor: pointer;
  }

  .signup-pill__input {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
  }

  .signup-pill__label {
    display: inline-block;
    padding: var(--space-xs) var(--space-md);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    line-height: var(--leading-snug);
    color: var(--color-text);
    background-color: transparent;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-pill);
    transition:
      background-color var(--duration-fast) var(--ease-standard),
      border-color var(--duration-fast) var(--ease-standard),
      color var(--duration-fast) var(--ease-standard);
    user-select: none;
  }

  .signup-pill__label:hover {
    border-color: var(--color-accent);
  }

  .signup-pill__input:checked + .signup-pill__label {
    background-color: var(--color-text);
    border-color: var(--color-text);
    color: var(--color-accent-contrast);
  }

  .signup-pill__input:focus-visible + .signup-pill__label {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .signup-form__name-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-block-end: var(--space-sm);
  }

  @media (min-width: 30em) {
    .signup-form__name-row {
      flex-direction: row;
    }

    .signup-form__name-row .signup-form__field {
      flex: 1;
    }
  }

  .signup-form__row {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    align-items: flex-start;
  }

  @media (min-width: 30em) {
    .signup-form__row {
      flex-direction: row;
      align-items: flex-end;
    }
  }

  .signup-success__text {
    font-size: var(--text-lg);
    font-weight: var(--weight-medium);
    color: var(--color-success);
    margin: 0;
    padding-block: var(--space-sm);
  }
</style>
