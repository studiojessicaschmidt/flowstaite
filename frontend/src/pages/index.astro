---
/*
 * Startseite
 *
 * Template-Gerüst für die Home-Page jedes Kundenprojekts. Enthält
 * absichtlich keine echten Inhalte, sondern sichtbare [KUNDE: ...]-
 * Platzhalter. Die Section-Reihenfolge (Hero, Über, Leistungen,
 * CTA, Kontakt-Teaser) gibt einen typischen Dienstleistungs-Funnel
 * vor und kann pro Projekt umgebaut werden.
 *
 * Sections sind semantisch als <section aria-labelledby="...">
 * ausgezeichnet, damit Screenreader eine klare Struktur bekommen.
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import Heading from "../components/ui/Heading.astro";
import Button from "../components/ui/Button.astro";
import Link from "../components/ui/Link.astro";
import ImagePlaceholder from "../components/ui/ImagePlaceholder.astro";
---

<BaseLayout
  title="[KUNDE: Seiten-Titel der Startseite]"
  description="[KUNDE: Kurze Meta-Description der Startseite, ein bis zwei Sätze.]"
>
  <section class="section section--hero" aria-labelledby="hero-heading">
    <Container size="default">
      <Heading level={1} id="hero-heading"> [KUNDE: Haupt-Headline für die Startseite] </Heading>
      <p class="section__lead">
        [KUNDE: Unterzeile, ein bis zwei Sätze, die das Kernangebot der Marke zusammenfassen.]
      </p>
      <p class="section__actions">
        <Button variant="primary" size="lg">[KUNDE: Primärer CTA-Text]</Button>
        <Link href="/leistungen" variant="standalone"> [KUNDE: Sekundärer Link-Text] </Link>
      </p>
      <ImagePlaceholder ratio="16 / 9" label="[KUNDE: Hero-Bild einsetzen]" />
    </Container>
  </section>

  <section class="section" aria-labelledby="about-heading">
    <Container size="default">
      <Heading level={2} id="about-heading"> [KUNDE: Überschrift Über-Section] </Heading>
      <p>
        [KUNDE: Kurzer Vorstellungstext, drei bis fünf Sätze, in denen die Marke, ihre Haltung und
        ihr Fokus umrissen werden.]
      </p>
      <ImagePlaceholder ratio="4 / 3" label="[KUNDE: Porträt oder Arbeitsfoto]" />
    </Container>
  </section>

  <section class="section" aria-labelledby="services-heading">
    <Container size="default">
      <Heading level={2} id="services-heading"> [KUNDE: Überschrift Leistungen-Section] </Heading>
      <p>[KUNDE: Kurzer einleitender Satz zur Leistungs-Übersicht.]</p>

      <div class="services">
        <article class="service">
          <Heading level={3}>[KUNDE: Leistung 1, Titel]</Heading>
          <p>[KUNDE: Leistung 1, Beschreibung in zwei bis drei Sätzen.]</p>
          <Link href="/leistungen" variant="standalone">Mehr erfahren</Link>
        </article>

        <article class="service">
          <Heading level={3}>[KUNDE: Leistung 2, Titel]</Heading>
          <p>[KUNDE: Leistung 2, Beschreibung in zwei bis drei Sätzen.]</p>
          <Link href="/leistungen" variant="standalone">Mehr erfahren</Link>
        </article>

        <article class="service">
          <Heading level={3}>[KUNDE: Leistung 3, Titel]</Heading>
          <p>[KUNDE: Leistung 3, Beschreibung in zwei bis drei Sätzen.]</p>
          <Link href="/leistungen" variant="standalone">Mehr erfahren</Link>
        </article>
      </div>
    </Container>
  </section>

  <section class="section section--cta" aria-labelledby="cta-heading">
    <Container size="narrow">
      <Heading level={2} id="cta-heading">
        [KUNDE: CTA-Überschrift, z.B. Lust auf ein gemeinsames Projekt?]
      </Heading>
      <p>[KUNDE: Kurzer Text, der zum nächsten Schritt einlädt, ein bis zwei Sätze.]</p>
      <p class="section__actions">
        <Button variant="primary" size="lg">[KUNDE: CTA-Button-Text]</Button>
      </p>
    </Container>
  </section>

  <section class="section" aria-labelledby="contact-heading">
    <Container size="narrow">
      <Heading level={2} id="contact-heading"> [KUNDE: Überschrift Kontakt-Section] </Heading>
      <p>
        [KUNDE: Kurzer Text zur Kontaktaufnahme, z.B. bevorzugte Wege und übliche Reaktionszeit.]
      </p>
      <p>
        <Link href="/kontakt" variant="standalone">Zur Kontaktseite</Link>
      </p>
    </Container>
  </section>
</BaseLayout>

<style>
  /*
   * Seitenspezifisches Layout für die Startseite.
   * Alle Werte kommen aus tokens.css.
   */

  .section {
    padding-block: var(--space-2xl);
  }

  .section__lead {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  .section__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
  }

  .section--cta {
    background-color: var(--color-surface);
    text-align: center;
  }

  /* Leistungen, dreispaltiges Grid ab 48em (--bp-md). */
  .services {
    display: grid;
    gap: var(--space-lg);
    margin-block-start: var(--space-lg);
  }

  @media (min-width: 48em) {
    .services {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .service {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }
</style>
