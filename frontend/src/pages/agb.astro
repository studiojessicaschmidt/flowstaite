---
/*
 * Allgemeine Geschäftsbedingungen
 *
 * Optionale Seite. Nur einsetzen, wenn das Kundenprojekt mit AGB
 * arbeitet (z.B. Online-Shop, digitale Buchungen, Dienstleistungen
 * mit Standardkonditionen). Wenn nicht benötigt, Seite und den
 * zugehörigen Footer-Link entfernen.
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import Heading from "../components/ui/Heading.astro";
---

<BaseLayout title="AGB, [KUNDE: Markenname]" description="Allgemeine Geschäftsbedingungen.">
  <section class="section" aria-labelledby="agb-heading">
    <Container size="narrow">
      <Heading level={1} id="agb-heading">Allgemeine Geschäftsbedingungen</Heading>
      <p>
        [KUNDE: AGB-Inhalt hier einfügen. Inhaltlich an die Angebote und Verkaufsprozesse dieser
        Website anpassen und idealerweise juristisch prüfen lassen. Falls für dieses Projekt keine
        AGB nötig sind, bitte den zugehörigen Footer-Link und diese Seite entfernen.]
      </p>
    </Container>
  </section>
</BaseLayout>

<style>
  .section {
    padding-block: var(--space-2xl);
  }
</style>
