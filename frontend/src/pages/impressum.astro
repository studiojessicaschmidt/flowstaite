---
/*
 * Impressum
 *
 * Pflicht-Seite nach § 5 TMG. Inhaltlich absichtlich leer, weil die
 * Verantwortung für Richtigkeit und Vollständigkeit beim Anbieter
 * liegt. Der Platzhalter-Text dokumentiert, welche Angaben erwartet
 * werden und warum hier kein Default-Text steht.
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import Heading from "../components/ui/Heading.astro";
---

<BaseLayout
  title="Impressum – flowstaite"
  description="Impressum und Anbieterkennzeichnung nach § 5 TMG."
>
  <section class="section" aria-labelledby="impressum-heading">
    <Container size="narrow">
      <Heading level={1} id="impressum-heading">Impressum</Heading>

      <p><strong>flowstaite.</strong><br />
      Verantwortlich: Jessica Schmidt</p>

      <h2>Adresse</h2>
      <p>Wittekindstraße 30,<br />
      33615 Bielefeld</p>

      <h2>Kontakt</h2>
      <p>E-Mail: <a href="mailto:hello@studiojessicaschmidt.de">hello@studiojessicaschmidt.de</a></p>

      <h2>Umsatzsteuer-ID</h2>
      <p>Umsatzsteuer-Identifikationsnummer gemäß § 27 a Umsatzsteuergesetz:<br />
      305/5934/6020</p>

      <p>Hinweis: Bei Fragen zum Impressum oder zur Website kontaktieren Sie mich gerne unter:<br />
      <a href="mailto:hello@studiojessicaschmidt.de">hello@studiojessicaschmidt.de</a></p>

      <p>Stand: Mai 2026</p>
    </Container>
  </section>
</BaseLayout>

<style>
  .section {
    padding-block: var(--space-2xl);
  }
</style>
