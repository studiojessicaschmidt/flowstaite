---
/*
 * Impressum
 *
 * Pflicht-Seite nach § 5 DDG (Digitale-Dienste-Gesetz, seit Mai 2024
 * Nachfolger des § 5 TMG). Die Angaben zum Anbieter sind
 * projektspezifisch und vom Betreiber auf Richtigkeit und
 * Vollständigkeit zu prüfen.
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import Heading from "../components/ui/Heading.astro";
---

<BaseLayout
  title="Impressum – flowstaite"
  description="Impressum und Anbieterkennzeichnung nach § 5 DDG."
>
  <section class="section" aria-labelledby="impressum-heading">
    <Container size="narrow">
      <Heading level={1} id="impressum-heading">Impressum</Heading>

      <p><strong>flowstaite.</strong><br />
      Verantwortlich: Jessica Schmidt</p>

      <h2>Adresse</h2>
      <p>Wittekindstraße 30,<br />
      33615 Bielefeld</p>

      <h2>Kontakt</h2>
      <p>E-Mail: <a href="mailto:hello@studiojessicaschmidt.de">hello@studiojessicaschmidt.de</a></p>

      <h2>Umsatzsteuer-ID</h2>
      <p>Umsatzsteuer-Identifikationsnummer gemäß § 27 a Umsatzsteuergesetz:<br />
      305/5934/6020</p>

      <p>Stand: Mai 2026</p>
    </Container>
  </section>
</BaseLayout>

<style>
  .section {
    padding-block: var(--space-2xl);
  }
</style>
