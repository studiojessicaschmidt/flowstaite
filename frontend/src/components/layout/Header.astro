---
/**
 * Header
 *
 * Seiten-Kopf mit Text-Wortmarke und Primär-Navigation. Responsive:
 * auf kleinen Viewports ist die Navigation hinter einem Toggle-Button
 * versteckt, auf größeren Viewports ist sie immer sichtbar.
 *
 * Navigations-Einträge werden als Prop übergeben, damit pro Seite oder
 * Kundenprojekt unterschiedliche Menüs möglich sind, ohne diese
 * Komponente zu verändern. Default-Einträge decken die üblichen vier
 * Top-Level-Seiten ab und sind als sichtbare Platzhalter formuliert.
 *
 * Interaktivität: siehe src/scripts/header-nav.ts. HTML, CSS und JS
 * bleiben strikt getrennt.
 */

import Container from "../ui/Container.astro";

interface NavItem {
  /** Sichtbarer Link-Text. */
  label: string;
  /** Ziel-URL. Bei leerem Kundenprojekt auf "#" setzen. */
  href: string;
}

interface Props {
  /** Sichtbarer Markenname im Header. Default ist ein sichtbarer Platzhalter. */
  brandName?: string;
  /** Ziel-URL der Wortmarke. Default Startseite. */
  brandHref?: string;
  /** Navigations-Einträge. Default vier neutrale Top-Level-Seiten. */
  navItems?: readonly NavItem[];
}

// Default-Einträge zeigen auf Platzhalter-Routen, die im Template
// absichtlich nicht alle als Seiten existieren. Nur "/" ist umgesetzt.
// Im Kundenprojekt vor Go-Live durch reale Seiten ersetzen. Die
// Handoff-Checkliste (Einheit 6) und PROJECT_SETUP.md (Einheit 8)
// enthalten dazu einen Checkpunkt.
const defaultNav: readonly NavItem[] = [];

const { brandName = "flowstaite", brandHref = "/", navItems = defaultNav } = Astro.props;
---

<header class="site-header">
  <Container as="div" size="default" class="site-header__inner">
    <a class="site-header__brand" href={brandHref} aria-label={brandName}>
      <img class="site-header__logo" src="/logo.svg" alt="" width="180" height="34" />
    </a>

    <div class="site-header__actions">
      {
        navItems.length > 0 && (
          <>
            <button
              class="site-header__toggle"
              type="button"
              data-nav-toggle
              aria-controls="primary-navigation"
              aria-expanded="false"
              aria-label="Menü öffnen"
            >
              <span class="site-header__toggle-bar" aria-hidden="true" />
              <span class="site-header__toggle-bar" aria-hidden="true" />
              <span class="site-header__toggle-bar" aria-hidden="true" />
            </button>

            <nav
              class="site-header__nav"
              id="primary-navigation"
              data-nav-primary
              data-state="closed"
              aria-label="Hauptnavigation"
            >
              <ul class="site-header__list">
                {navItems.map((item) => (
                  <li class="site-header__item">
                    <a class="site-header__link" href={item.href}>
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </>
        )
      }

      <a class="site-header__cta" href="#dabei-sein">Mehr erfahren</a>
    </div>
  </Container>
</header>

<script>
  import "../../scripts/header-nav";
</script>

<style>
  .site-header {
    position: fixed;
    inset-inline: 0;
    inset-block-start: 0;
    z-index: var(--z-sticky);
    background-color: rgba(255, 244, 223, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding-block: var(--space-sm);
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    color: var(--color-text);
    text-decoration: none;
    line-height: 0;
  }

  .site-header__logo {
    display: block;
    height: clamp(1rem, 2.5vw, 1.5rem);
    width: auto;
  }

  .site-header__brand:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  /* ------------------------------------------------------------------
   * Toggle-Button, nur bis 48em sichtbar.
   * ------------------------------------------------------------------ */

  .site-header__toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: space-between;
    width: var(--space-md);
    height: var(--space-md);
    padding: 0;
    background: none;
    border: 0;
    cursor: pointer;
    color: var(--color-text);
  }

  .site-header__toggle-bar {
    display: block;
    width: 100%;
    height: 2px;
    background-color: currentColor;
    border-radius: var(--radius-sm);
  }

  /* ------------------------------------------------------------------
   * Navigation
   * Mobile-Default: versteckt, öffnet sich als Drop-Panel unter dem Header.
   * Ab 48em: permanent sichtbar, horizontale Liste.
   * ------------------------------------------------------------------ */

  .site-header__nav[data-state="closed"] {
    display: none;
  }

  .site-header__nav[data-state="open"] {
    display: block;
    position: absolute;
    inset-inline: 0;
    inset-block-start: 100%;
    background-color: var(--color-bg);
    border-block-end: 1px solid var(--color-border);
    padding-block: var(--space-sm);
  }

  .site-header__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    margin: 0;
    padding-inline: var(--container-pad-inline);
    list-style: none;
  }

  .site-header__item + .site-header__item {
    margin-block-start: 0;
  }

  .site-header__link {
    display: inline-block;
    padding-block: var(--space-2xs);
    color: var(--color-text);
    text-decoration: none;
    font-weight: var(--weight-medium);
  }

  .site-header__link:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .site-header__cta {
    display: inline-block;
    padding: var(--space-xs) var(--space-md);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    line-height: var(--leading-snug);
    color: var(--color-accent-contrast);
    background-color: var(--color-text);
    border-radius: var(--radius-pill);
    text-decoration: none;
    white-space: nowrap;
    transition: opacity var(--duration-fast) var(--ease-standard);
  }

  .site-header__cta:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  .site-header__cta:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  /* 48em entspricht --bp-md aus tokens.css. */
  @media (min-width: 48em) {
    .site-header__toggle {
      display: none;
    }

    .site-header__nav,
    .site-header__nav[data-state="closed"],
    .site-header__nav[data-state="open"] {
      display: block;
      position: static;
      padding: 0;
      border: 0;
      background: none;
    }

    .site-header__list {
      flex-direction: row;
      gap: var(--space-md);
      padding-inline: 0;
    }
  }
</style>
