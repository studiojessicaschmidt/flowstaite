---
/**
 * Footer
 *
 * Seiten-Fuß mit drei Bereichen:
 * 1. Rechts-Links: Impressum, Datenschutz, AGB, Erklärung zur Barrierefreiheit.
 * 2. Social-Links: Instagram, LinkedIn, Pinterest als Platzhalter-Defaults.
 * 3. Studio-Credit: Pflichttext "Website erstellt und designed von
 *    Studio Jessica Schmidt" mit Link auf studiojessicaschmidt.de.
 *
 * Der Studio-Credit ist in jedem auf Basis dieses Templates gebauten
 * Projekt verpflichtend. Siehe CLAUDE.md.
 */

import Container from "../ui/Container.astro";

interface FooterLink {
  /** Sichtbarer Link-Text. */
  label: string;
  /** Ziel-URL. */
  href: string;
}

interface Props {
  /** Rechts-Links. Default deckt Impressum, Datenschutz, AGB und Barrierefreiheit ab. */
  legalLinks?: readonly FooterLink[];
  /** Social-Links. Default ist ein Satz sichtbarer Platzhalter. */
  socialLinks?: readonly FooterLink[];
}

const defaultLegalLinks: readonly FooterLink[] = [
  { label: "Impressum", href: "/impressum" },
  { label: "Datenschutz", href: "/datenschutz" },
  { label: "AGB", href: "/agb" },
  { label: "Erklärung zur Barrierefreiheit", href: "/barrierefreiheit" },
];

const defaultSocialLinks: readonly FooterLink[] = [
  { label: "Instagram", href: "[KUNDE: Instagram-URL]" },
  { label: "LinkedIn", href: "[KUNDE: LinkedIn-URL]" },
  { label: "Pinterest", href: "[KUNDE: Pinterest-URL]" },
];

const { legalLinks = defaultLegalLinks, socialLinks = defaultSocialLinks } = Astro.props;

// Aktuelles Jahr für den Copyright-Hinweis, in Berlin-Zeit nicht zeitzonen-kritisch.
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <Container as="div" size="default" class="site-footer__inner">
    <nav class="site-footer__section" aria-label="Rechtliche Hinweise">
      <ul class="site-footer__list">
        {
          legalLinks.map((item) => (
            <li class="site-footer__item">
              <a class="site-footer__link" href={item.href}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <nav class="site-footer__section" aria-label="Social Media">
      <ul class="site-footer__list">
        {
          socialLinks.map((item) => (
            <li class="site-footer__item">
              <a
                class="site-footer__link"
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="site-footer__section site-footer__credit">
      <p class="site-footer__copyright">
        © {currentYear} [KUNDE: Markenname]
      </p>
      <p class="site-footer__studio">
        Website erstellt und designed von
        <a
          class="site-footer__link"
          href="https://studiojessicaschmidt.de"
          target="_blank"
          rel="noopener noreferrer">Studio Jessica Schmidt</a
        >
      </p>
    </div>
  </Container>
</footer>

<style>
  .site-footer {
    margin-block-start: var(--space-3xl);
    padding-block: var(--space-xl);
    background-color: var(--color-surface);
    border-block-start: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  .site-footer__section {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .site-footer__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-footer__item + .site-footer__item {
    margin-block-start: 0;
  }

  .site-footer__link {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-decoration-thickness: 1px;
  }

  .site-footer__link:hover {
    text-decoration-thickness: 2px;
  }

  .site-footer__copyright,
  .site-footer__studio {
    margin: 0;
  }

  .site-footer__credit {
    gap: var(--space-3xs);
  }

  /* Ab 48em drei nebeneinanderliegende Spalten. */
  @media (min-width: 48em) {
    .site-footer__inner {
      grid-template-columns: repeat(3, 1fr);
      align-items: start;
    }
  }
</style>
