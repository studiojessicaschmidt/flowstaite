---
/**
 * Button
 *
 * Interaktions-Button. Rendert immer ein echtes <button>-Element.
 * Für Navigationslinks mit Button-Optik bitte die Link-Komponente
 * mit einer eigenen Variante nutzen, nicht diesen Button als Link
 * zweckentfremden (Accessibility-Baseline: Buttons tun etwas,
 * Links navigieren).
 */

import type { HTMLAttributes } from "astro/types";

/** Visuelle Variante. */
type ButtonVariant = "primary" | "secondary" | "ghost";

/** Größe, steuert Padding und Schriftgröße. */
type ButtonSize = "sm" | "md" | "lg";

interface Props extends HTMLAttributes<"button"> {
  /** Visuelle Variante. Default "primary". */
  variant?: ButtonVariant;
  /** Größe. Default "md". */
  size?: ButtonSize;
}

const {
  variant = "primary",
  size = "md",
  // Explizites Default: verhindert, dass der Button in einem Form
  // ungewollt als Submit-Button interpretiert wird.
  type = "button",
  class: extraClass,
  ...rest
} = Astro.props;
---

<button
  type={type}
  class:list={["button", `button--${variant}`, `button--${size}`, extraClass]}
  {...rest}
>
  <slot />
</button>

<style>
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2xs);
    font-family: var(--font-sans);
    font-weight: var(--weight-medium);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-normal);
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    cursor: pointer;
    text-decoration: none;
    transition:
      background-color var(--duration-fast) var(--ease-standard),
      color var(--duration-fast) var(--ease-standard),
      border-color var(--duration-fast) var(--ease-standard);
  }

  .button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Größen */
  .button--sm {
    padding: var(--space-2xs) var(--space-sm);
    font-size: var(--text-sm);
  }

  .button--md {
    padding: var(--space-xs) var(--space-md);
    font-size: var(--text-base);
  }

  .button--lg {
    padding: var(--space-sm) var(--space-lg);
    font-size: var(--text-lg);
  }

  /* Varianten */
  .button--primary {
    background-color: var(--color-accent);
    color: var(--color-accent-contrast);
    border-color: var(--color-accent);
  }

  .button--primary:hover:not(:disabled) {
    background-color: var(--color-text);
    border-color: var(--color-text);
  }

  .button--secondary {
    background-color: var(--color-bg);
    color: var(--color-text);
    border-color: var(--color-border-strong);
  }

  .button--secondary:hover:not(:disabled) {
    background-color: var(--color-surface);
  }

  .button--ghost {
    background-color: transparent;
    color: var(--color-text);
    border-color: transparent;
  }

  .button--ghost:hover:not(:disabled) {
    background-color: var(--color-surface);
  }
</style>
