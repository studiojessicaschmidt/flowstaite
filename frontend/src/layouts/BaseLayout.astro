---
/**
 * BaseLayout
 *
 * Grundgerüst für jede Seite des Templates. Rendert:
 * - <html>-Dokument mit lang-Attribut
 * - <head> via SeoHead-Komponente
 * - <body> mit SkipLink, Header, <main id="main-content"> und Footer
 *
 * Die drei Basis-Stylesheets (tokens, reset, global) werden hier einmal
 * importiert und sind damit für jede Seite verfügbar, die dieses Layout
 * nutzt. Einzelne Seiten importieren keine CSS-Dateien mehr direkt.
 */

// Fonts, lokal über @fontsource ausgeliefert (kein Google-Fonts-CDN, DSGVO-freundlich).
// Source Serif 4 für Headlines, Radio Canada Big für Mengentext.
import "@fontsource/source-serif-4/400.css";
import "@fontsource/source-serif-4/600.css";
import "@fontsource/source-serif-4/700.css";
import "@fontsource/radio-canada-big/400.css";
import "@fontsource/radio-canada-big/500.css";
import "@fontsource/radio-canada-big/700.css";

import "../styles/tokens.css";
import "../styles/reset.css";
import "../styles/global.css";

import SeoHead from "../components/seo/SeoHead.astro";
import SkipLink from "../components/layout/SkipLink.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

interface Props {
  /** Seiten-Titel, z. B. "Impressum, Kundenname". Pflicht. */
  title: string;
  /** Kurze Seiten-Beschreibung für SEO und Open Graph. Pflicht. */
  description: string;
  /** Sprache des Dokuments. Default "de". */
  lang?: string;
  /** Absolute Canonical-URL. Optional. */
  canonical?: string;
  /** Absolute URL zu einem Open-Graph-Bild. Optional. */
  ogImage?: string;
  /** Wenn true, wird robots auf noindex,nofollow gesetzt. Default false. */
  noindex?: boolean;
}

const { title, description, lang = "de", canonical, ogImage, noindex = false } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      noindex={noindex}
    />
  </head>
  <body>
    <SkipLink />
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
